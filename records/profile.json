{
  "id": "github.com/humanagencyprotocol/hap-profiles/records@0.4",
  "name": "Records",
  "version": "0.4",
  "description": "Records authority — governs accessing and modifying personal structured data: queries, schema changes, exports",

  "boundsSchema": {
    "keyOrder": ["profile", "path", "row_limit_max", "query_count_daily_max", "export_row_count_daily_max"],
    "fields": {
      "profile": { "type": "string", "required": true },
      "path": { "type": "string", "required": true },
      "row_limit_max": {
        "type": "number",
        "required": true,
        "displayName": "Row limit per query",
        "description": "Maximum rows returned per query",
        "constraint": { "type": "number", "enforceable": ["max"] }
      },
      "query_count_daily_max": {
        "type": "number",
        "required": true,
        "displayName": "Daily query limit",
        "description": "Maximum queries per day",
        "constraint": { "type": "number", "enforceable": ["max"] }
      },
      "export_row_count_daily_max": {
        "type": "number",
        "required": true,
        "displayName": "Daily export row limit",
        "description": "Maximum exported rows per day",
        "constraint": { "type": "number", "enforceable": ["max"] }
      }
    }
  },

  "contextSchema": {
    "keyOrder": ["access_level", "data_scope", "scope"],
    "fields": {
      "access_level": {
        "type": "string",
        "required": true,
        "displayName": "Access level",
        "description": "Authorized access level",
        "constraint": { "type": "string", "enforceable": ["enum"] },
        "enum": ["read", "write", "admin"]
      },
      "data_scope": {
        "type": "string",
        "required": true,
        "displayName": "Data scope",
        "description": "Data scope authorization",
        "constraint": { "type": "string", "enforceable": ["enum"] },
        "enum": ["public", "internal", "pii"]
      },
      "scope": {
        "type": "string",
        "required": true,
        "displayName": "Impact scope",
        "description": "Impact scope (external = production data, internal = sandbox/test data)",
        "constraint": { "type": "string", "enforceable": ["enum"] },
        "enum": ["external", "internal"]
      }
    }
  },

  "executionContextSchema": {
    "fields": {
      "access_level": {
        "source": "declared",
        "description": "Access level for this operation",
        "required": true,
        "constraint": { "type": "string", "enforceable": ["enum"] }
      },
      "data_scope": {
        "source": "declared",
        "description": "Data scope being accessed",
        "required": true,
        "constraint": { "type": "string", "enforceable": ["enum"] }
      },
      "scope": {
        "source": "declared",
        "description": "Impact scope of this data operation",
        "required": true,
        "constraint": { "type": "string", "enforceable": ["enum"] }
      },
      "row_limit": {
        "source": "declared",
        "description": "Number of rows in this query result",
        "required": true,
        "constraint": { "type": "number", "enforceable": ["max"] }
      },
      "query_count_daily": {
        "source": "cumulative",
        "cumulativeField": "_count",
        "window": "daily",
        "description": "Running daily query count (resolved from execution log)",
        "required": true,
        "constraint": { "type": "number", "enforceable": ["max"] }
      },
      "export_row_count_daily": {
        "source": "cumulative",
        "cumulativeField": "row_limit",
        "window": "daily",
        "description": "Running daily exported row count (resolved from execution log)",
        "required": true,
        "constraint": { "type": "number", "enforceable": ["max"] }
      }
    }
  },

  "executionPaths": {
    "records-read": {
      "description": "Read-only queries against personal data",
      "ttl": { "default": 28800, "max": 86400 }
    },
    "records-write": {
      "description": "Create and modify personal records",
      "ttl": { "default": 7200, "max": 86400 }
    },
    "records-export": {
      "description": "Bulk exports of personal data",
      "ttl": { "default": 3600, "max": 86400 }
    }
  },

  "requiredGates": ["bounds", "problem", "objective", "tradeoff", "commitment", "decision_owner"],

  "gateQuestions": {
    "problem": { "question": "What problem does this records authority address?", "required": true },
    "objective": { "question": "What outcome should this records authority enable?", "required": true },
    "tradeoffs": { "question": "What data risks do you accept with this authority?", "required": true }
  },

  "ttl": { "default": 28800, "max": 86400 },
  "retention_minimum": 7776000
}
